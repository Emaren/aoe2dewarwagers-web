# ───────── common ─────────
# In production this app expects browser API calls to stay same-origin.
NEXT_PUBLIC_CHAIN_ID=11865

# ───────── server-only ────
# Used by Prisma tooling and server routes.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# SESSION_SECRET=replace-with-long-random-secret
# AOE2_BACKEND_UPSTREAM=http://127.0.0.1:4400
# ADMIN_TOKEN=replace-with-admin-token
# INTERNAL_API_KEY=replace-with-shared-upload-key
# STEAM_API_KEY=steam-web-api-key-for-persona-lookups
# ALLOW_GUEST_SESSIONS=false
# DIRECT_MESSAGE_ATTACHMENT_DIR=/mnt/HC_Volume_105319120/www-moved/AoE2DEWarWagers/app-prodn/storage/direct-message-attachments
# STAKING_REWARD_RUN_TOKEN=replace-with-long-random-cron-token
# STAKING_REWARD_RUN_URL=http://127.0.0.1:4000

# ───────── Lobby Advanced / WOLO market ─────────
# Optional display config for the Advanced lobby market tile and ticker.
# WOLO_OSMOSIS_POOL_ID=3461
# WOLO_OSMOSIS_POOL_URL=https://app.osmosis.zone/pool/3461
# WOLO_OSMOSIS_LCD_URL=https://lcd.osmosis.zone
# WOLO_OSMOSIS_USDC_DENOM=ibc/498A0751C798A0D9A389AA3691123DADA57DAA4FE165D5C75894505B876BA6E4
# WOLO_OSMOSIS_WOLO_DENOM=ibc/D09120C7085DFA412DF77608DAD3A4797F5F097A038DA0C2E1D1426FC9CD836D
# WOLO_MARKET_LABEL=WOLO Market
# WOLO_USD_PRICE=0.0001102 # optional manual override; omit to derive from pool 3461

# ───────── WOLO staking / custody ─────────
# Public chain endpoints used by Keplr and server-side WOLO reads.
# NEXT_PUBLIC_WOLO_CHAIN_ID=wolo-1
# NEXT_PUBLIC_WOLO_RPC_URL=https://rpc-mainnet.aoe2war.com
# WOLO_RPC_URL=https://rpc-mainnet.aoe2war.com
# NEXT_PUBLIC_WOLO_REST_URL=https://rest-mainnet.aoe2war.com
# WOLO_REST_URL=https://rest-mainnet.aoe2war.com
# Server-only local endpoints for a network-restricted production service.
# WOLO_INTERNAL_RPC_URL=http://127.0.0.1:27657
# WOLO_INTERNAL_REST_URL=http://127.0.0.1:1318
# WOLO_MAINNET_DISPLAY_START_AT=2026-05-25T00:00:00.000Z
#
# Staking wallet custody. Users stake into this address through Keplr.
# NEXT_PUBLIC_WOLO_STAKING_WALLET_ADDRESS=wolo...
# WOLO_STAKING_WALLET_ADDRESS=wolo...
#
# Server-only signer for returning principal on unstake. This must resolve to
# WOLO_STAKING_WALLET_ADDRESS; unstake no longer uses the generic payout rail.
# WOLO_STAKING_WALLET_MNEMONIC=replace-with-staking-wallet-mnemonic
# WOLO_STAKING_UNSTAKE_FEE=auto
# WOLO_STAKING_UNSTAKE_HEADROOM_UWOLO=10000000


# Staking unstake execution: prefer local WoloChain keyring signer, not web-stored mnemonic.
# WOLO_STAKING_CLI=/usr/local/bin/wolochaind-mainnet
# WOLO_STAKING_HOME=/var/lib/aoe2dewarwagers-wolo-mainnet
# WOLO_STAKING_KEY_NAME=staking
# WOLO_STAKING_KEYRING_BACKEND=file
# WOLO_STAKING_CHAIN_ID=wolo-1
# WOLO_STAKING_NODE_RPC=http://127.0.0.1:27657
# WOLO_STAKING_UNSTAKE_FEE=5000uwolo
# WOLO_STAKING_UNSTAKE_HEADROOM_UWOLO=10000000

# ───────── WOLO mainnet faucet app signer ─────────
# Uses the wolo-1 app signer home and RPC, not local testnet.
# WOLO_FAUCET_CLI=/usr/local/bin/wolochaind-mainnet
# WOLO_FAUCET_HOME=/var/lib/aoe2dewarwagers-wolo-mainnet
# WOLO_FAUCET_FROM=faucet-hot-mainnet
# WOLO_FAUCET_ADDRESS=wolo1dshyzxffd0jj39k7gj9tq9hgsx96ylxamyp5g0
# WOLO_FAUCET_CHAIN_ID=wolo-1
# WOLO_FAUCET_NODE_RPC=http://127.0.0.1:27657
# Current production uses the Cosmos "test" keyring backend inside the wolo-1
# app signer home; this is key storage, not the wolo-testnet chain.
# WOLO_FAUCET_KEYRING_BACKEND=test
# WOLO_FAUCET_FEE=5000uwolo

# ───────── WOLO mainnet settlement ─────────
# Set these only when http://127.0.0.1:8092/settlement/v1/health reports
# ok=true on chain_id=wolo-1. Never use 127.0.0.1:8091 for mainnet; that
# is the wolo-testnet settlement service.
# WOLO_SETTLEMENT_URL=http://127.0.0.1:8092
# WOLO_SETTLEMENT_AUTH_TOKEN=copy-from-root-only-wolochain-mainnet-settlement-env
# WOLO_BET_PAYOUT_ADDRESS=wolo1zfa9ssu2gpgqg7yzvhmjt4w66mza07qr2a4rwu
# WOLO_BET_ESCROW_ADDRESS=wolo1zygwt232ymc4h2g52yvkntffhmd5alx2kglw7p
# NEXT_PUBLIC_WOLO_BET_ESCROW_ADDRESS=wolo1zygwt232ymc4h2g52yvkntffhmd5alx2kglw7p
# Challenge funding uses the signer-backed Bet Escrow address above. The browser
# receives it from the runtime challenge snapshot, so a separate public
# NEXT_PUBLIC_WOLO_CHALLENGE_ESCROW_ADDRESS is not required.
# WOLO_COMMUNITY_TREASURY_ADDRESS=wolo1hlfvzuv4dc46ngvh3zlteuegx0xga20hj20zd2
