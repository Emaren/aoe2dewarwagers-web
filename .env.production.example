# ───────── common ─────────
# In production this app expects browser API calls to stay same-origin.
NEXT_PUBLIC_CHAIN_ID=11865

# ───────── server-only ────
# Used by Prisma tooling and server routes.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# SESSION_SECRET=replace-with-long-random-secret
# AOE2_BACKEND_UPSTREAM=http://127.0.0.1:3330
# ADMIN_TOKEN=replace-with-admin-token
# INTERNAL_API_KEY=replace-with-shared-upload-key
# STEAM_API_KEY=steam-web-api-key-for-persona-lookups
# ALLOW_GUEST_SESSIONS=false
# DIRECT_MESSAGE_ATTACHMENT_DIR=/var/www/AoE2HDBets/app-prodn/storage/direct-message-attachments
