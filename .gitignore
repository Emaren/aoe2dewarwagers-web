# Ignored by default:
node_modules/
.next/
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/versions/

# Also ignore build and lock files
.next/
.next-cache/
dist/
build/
*.log
.envrc
.direnv/
.python-version
.env
.env.*

/lib/generated/prisma

# macOS metadata
.DS_Store

# VPS-local artifacts
data.json
next.config.js.bak.*
testdameon
aoe2hd-frontend-clean.git/
*.bfg-report/
-

# TypeScript incremental artifacts
tsconfig.tsbuildinfo

!.env.production.example

# local mkcert outputs (generated by npm run dev)
localhost*.pem
localhost*-key.pem

# local legacy assets (keep tracked if you want; remove if you DO want them tracked)
# (leave commented unless you want to ignore the whole folder)
# public/legacy/

# local backups
**/*.bak-*

# AoE2 watcher release artifacts
public/downloads/aoe2-watcher-mac.zip
public/downloads/aoe2-watcher-manual.zip
public/downloads/aoe2hd-watcher-*.dmg
public/downloads/aoe2hd-watcher-*.dmg.blockmap
public/downloads/latest-mac.yml

# Local direct-message attachment blobs
storage/direct-message-attachments/

# Local faucet cooldown ledger
storage/wolo-faucet/

# local watcher release artifacts
public/downloads/
