generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  uid           String    @unique @db.VarChar(100)
  email         String?   @unique(map: "ix_users_email") @db.VarChar(100)
  inGameName    String?   @unique @map("in_game_name") @db.VarChar
  verified      Boolean   @default(false)
  walletAddress String?   @map("wallet_address") @db.VarChar(100)
  lockName      Boolean   @default(false) @map("lock_name")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  token         String?   @db.VarChar(128)
  lastSeen      DateTime? @map("last_seen") @db.Timestamp(6)
  isAdmin       Boolean   @default(false) @map("is_admin")

  // NOTE: DB has a partial unique index (WHERE steam_id IS NOT NULL).
  // Prisma can't represent partial uniqueness here, so we map to the index name
  // and rely on the DB for enforcement.
  steamId            String?   @unique(map: "uq_users_steam_id") @map("steam_id") @db.VarChar(32)
  steamPersonaName   String?   @map("steam_persona_name") @db.VarChar(255)
  verificationLevel  Int       @default(0) @map("verification_level")
  verificationMethod String    @default("none") @map("verification_method") @db.VarChar(32)
  verifiedAt         DateTime? @map("verified_at") @db.Timestamp(6)

  apiKeys                        ApiKey[]
  gameStats                      GameStats[]
  tournamentEntries              TournamentEntry[]
  chatMessages                   ChatMessage[]
  chatMessageReactions           ChatMessageReaction[]
  createdTournaments             Tournament[]                    @relation("TournamentCreator")
  directConversationParticipants DirectConversationParticipant[] @relation("DirectConversationParticipantUser")
  directMessagesSent             DirectMessage[]                 @relation("DirectMessageSender")
  directMessageReactions         DirectMessageReaction[]
  communityRequestsCreated       CommunityRequest[]              @relation("CommunityRequestAuthor")
  communityRequestsCompleted     CommunityRequest[]              @relation("CommunityRequestCompleter")
  communityRequestVotes          CommunityRequestVote[]
  communityRequestComments       CommunityRequestComment[]       @relation("CommunityRequestCommentAuthor")
  receivedBadges                 UserBadge[]                     @relation("UserBadgeRecipient")
  grantedBadges                  UserBadge[]                     @relation("UserBadgeCreator")
  receivedGifts                  UserGift[]                      @relation("UserGiftRecipient")
  grantedGifts                   UserGift[]                      @relation("UserGiftCreator")
  appearancePreference           UserAppearancePreference?
  activityEvents                 UserActivityEvent[]
  watcherDownloadEvents          WatcherDownloadEvent[]
  betWagers                      BetWager[]
  betStakeIntents                BetStakeIntent[]
  betMarketWallets               BetMarketWallet[]
  createdBetFounderBonuses       BetMarketFounderBonus[]        @relation("BetMarketFounderBonusCreator")
  scheduledChallengesCreated     ScheduledMatch[]                @relation("ScheduledMatchChallenger")
  scheduledChallengesReceived    ScheduledMatch[]                @relation("ScheduledMatchChallenged")
  scheduledMatchActivities       ScheduledMatchActivity[]        @relation("ScheduledMatchActivityActor")

  @@map("users")
}

model ApiKey {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  kind       String    @default("watcher") @db.VarChar(20)
  keyPrefix  String    @unique @map("key_prefix") @db.VarChar(12)
  keyHash    String    @map("key_hash") @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamp(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "ix_api_keys_user_id")
  @@index([keyPrefix], map: "ix_api_keys_prefix")
  @@map("api_keys")
}

model GameStats {
  id                  Int       @id @default(autoincrement())
  userUid             String?   @map("user_uid") @db.VarChar(100)
  replay_file         String    @db.VarChar(500)
  replayHash          String    @map("replay_hash") @db.VarChar(64)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  game_version        String?   @db.VarChar(50)
  map                 Json?
  game_type           String?   @db.VarChar(50)
  duration            Int?
  game_duration       Int?
  winner              String?   @db.VarChar(100)
  players             Json?
  event_types         Json?
  key_events          Json?
  timestamp           DateTime? @default(now()) @db.Timestamp(6)
  played_on           DateTime? @db.Timestamp(6)
  parse_iteration     Int       @default(0)
  is_final            Boolean   @default(false)
  disconnect_detected Boolean   @default(false)
  parse_source        String    @default("unknown") @db.VarChar(20)
  parse_reason        String    @default("unspecified") @db.VarChar(50)
  original_filename   String?   @db.VarChar(255)

  user                 User?                @relation(fields: [userUid], references: [uid], onDelete: NoAction, onUpdate: NoAction)
  linkedBetMarkets     BetMarket[]          @relation("BetMarketLinkedGameStats")
  tournamentMatchProof TournamentMatch?     @relation("TournamentMatchProof")
  replayParseAttempts  ReplayParseAttempt[] @relation("GameStatsParseAttempts")

  @@unique([replayHash, is_final], map: "uq_replay_final")
  @@index([userUid], map: "ix_game_stats_user_uid")
  @@index([replayHash, parse_iteration], map: "ix_replay_hash_iteration")
  @@index([replay_file, parse_iteration], map: "ix_replay_iteration")
  @@map("game_stats")
}

model ReplayParseAttempt {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  userUid          String?   @map("user_uid") @db.VarChar(100)
  replayHash       String?   @map("replay_hash") @db.VarChar(64)
  originalFilename String?   @map("original_filename") @db.VarChar(255)
  parseSource      String    @default("file_upload") @map("parse_source") @db.VarChar(20)
  status           String    @default("received") @db.VarChar(32)
  detail           String?   @db.VarChar(255)
  uploadMode       String?   @map("upload_mode") @db.VarChar(20)
  fileSizeBytes    Int?      @map("file_size_bytes")
  gameStatsId      Int?      @map("game_stats_id")
  playedOn         DateTime? @map("played_on") @db.Timestamp(6)

  gameStats GameStats? @relation("GameStatsParseAttempts", fields: [gameStatsId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([createdAt], map: "ix_replay_parse_attempts_created_at")
  @@index([status, createdAt], map: "ix_replay_parse_attempts_status_created_at")
  @@index([userUid, createdAt], map: "ix_replay_parse_attempts_user_uid_created_at")
  @@index([replayHash], map: "ix_replay_parse_attempts_replay_hash")
  @@index([gameStatsId], map: "ix_replay_parse_attempts_game_stats_id")
  @@map("replay_parse_attempts")
}

model Tournament {
  id              Int       @id @default(autoincrement())
  slug            String    @unique @db.VarChar(80)
  title           String    @db.VarChar(120)
  description     String?   @db.Text
  format          String    @default("1v1 AoE2HD showcase") @db.VarChar(80)
  status          String    @default("planning") @db.VarChar(20)
  startsAt        DateTime? @map("starts_at") @db.Timestamp(6)
  featured        Boolean   @default(false)
  createdByUserId Int?      @map("created_by_user_id")
  chatRoomId      Int?      @unique(map: "uq_tournaments_chat_room_id") @map("chat_room_id")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  chatRoom  ChatRoom?         @relation(fields: [chatRoomId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  createdBy User?             @relation("TournamentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  entries   TournamentEntry[]
  matches   TournamentMatch[]

  @@index([featured, startsAt], map: "ix_tournaments_featured_starts_at")
  @@index([status, startsAt], map: "ix_tournaments_status_starts_at")
  @@map("tournaments")
}

model TournamentEntry {
  id           Int      @id @default(autoincrement())
  tournamentId Int      @map("tournament_id")
  userId       Int      @map("user_id")
  status       String   @default("joined") @db.VarChar(20)
  note         String?  @db.VarChar(160)
  joinedAt     DateTime @default(now()) @map("joined_at") @db.Timestamp(6)

  tournament       Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  playerOneMatches TournamentMatch[] @relation("TournamentMatchPlayerOne")
  playerTwoMatches TournamentMatch[] @relation("TournamentMatchPlayerTwo")
  winnerMatches    TournamentMatch[] @relation("TournamentMatchWinner")

  @@unique([tournamentId, userId], map: "uq_tournament_entries_tournament_user")
  @@index([userId], map: "ix_tournament_entries_user_id")
  @@index([tournamentId, joinedAt], map: "ix_tournament_entries_tournament_joined_at")
  @@map("tournament_entries")
}

model TournamentMatch {
  id                Int       @id @default(autoincrement())
  tournamentId      Int       @map("tournament_id")
  round             Int       @default(1)
  position          Int       @default(1)
  label             String?   @db.VarChar(80)
  status            String    @default("scheduled") @db.VarChar(20)
  sourceGameStatsId Int?      @unique(map: "uq_tournament_matches_source_game_stats_id") @map("source_game_stats_id")
  playerOneEntryId  Int?      @map("player_one_entry_id")
  playerTwoEntryId  Int?      @map("player_two_entry_id")
  winnerEntryId     Int?      @map("winner_entry_id")
  scheduledAt       DateTime? @map("scheduled_at") @db.Timestamp(6)
  completedAt       DateTime? @map("completed_at") @db.Timestamp(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  tournament      Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sourceGameStats GameStats?       @relation("TournamentMatchProof", fields: [sourceGameStatsId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  playerOne       TournamentEntry? @relation("TournamentMatchPlayerOne", fields: [playerOneEntryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  playerTwo       TournamentEntry? @relation("TournamentMatchPlayerTwo", fields: [playerTwoEntryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  winner          TournamentEntry? @relation("TournamentMatchWinner", fields: [winnerEntryId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([tournamentId, round, position], map: "uq_tournament_matches_round_position")
  @@index([tournamentId, status], map: "ix_tournament_matches_tournament_status")
  @@index([scheduledAt], map: "ix_tournament_matches_scheduled_at")
  @@map("tournament_matches")
}

model ScheduledMatch {
  id                    Int                      @id @default(autoincrement())
  challengerUserId      Int                      @map("challenger_user_id")
  challengedUserId      Int                      @map("challenged_user_id")
  status                String                   @default("pending") @db.VarChar(20)
  scheduledAt           DateTime                 @map("scheduled_at") @db.Timestamp(6)
  challengeNote         String?                  @map("challenge_note") @db.VarChar(160)
  acceptedAt            DateTime?                @map("accepted_at") @db.Timestamp(6)
  declinedAt            DateTime?                @map("declined_at") @db.Timestamp(6)
  cancelledAt           DateTime?                @map("cancelled_at") @db.Timestamp(6)
  resultAt              DateTime?                @map("result_at") @db.Timestamp(6)
  linkedSessionKey      String?                  @map("linked_session_key") @db.VarChar(255)
  linkedMapName         String?                  @map("linked_map_name") @db.VarChar(120)
  linkedWinner          String?                  @map("linked_winner") @db.VarChar(100)
  linkedDurationSeconds Int?                     @map("linked_duration_seconds")
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime                 @updatedAt @map("updated_at") @db.Timestamp(6)
  activities            ScheduledMatchActivity[]

  challenger User       @relation("ScheduledMatchChallenger", fields: [challengerUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  challenged User       @relation("ScheduledMatchChallenged", fields: [challengedUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  betMarket  BetMarket?

  @@index([status, scheduledAt], map: "ix_scheduled_matches_status_scheduled_at")
  @@index([challengerUserId, scheduledAt], map: "ix_scheduled_matches_challenger_scheduled_at")
  @@index([challengedUserId, scheduledAt], map: "ix_scheduled_matches_challenged_scheduled_at")
  @@index([status, resultAt], map: "ix_scheduled_matches_status_result_at")
  @@map("scheduled_matches")
}

model ScheduledMatchActivity {
  id               Int      @id @default(autoincrement())
  scheduledMatchId Int      @map("scheduled_match_id")
  actorUserId      Int?     @map("actor_user_id")
  eventType        String   @map("event_type") @db.VarChar(32)
  detail           String?  @db.VarChar(255)
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  scheduledMatch ScheduledMatch @relation(fields: [scheduledMatchId], references: [id], onDelete: Cascade)
  actor          User?          @relation("ScheduledMatchActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([scheduledMatchId, createdAt], map: "ix_scheduled_match_activities_match_created_at")
  @@index([actorUserId, createdAt], map: "ix_scheduled_match_activities_actor_created_at")
  @@index([eventType, createdAt], map: "ix_scheduled_match_activities_type_created_at")
  @@map("scheduled_match_activities")
}

model ChatRoom {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(120)
  description String?  @db.Text
  scope       String   @default("lobby") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  messages   ChatMessage[]
  tournament Tournament?

  @@map("chat_rooms")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  roomId    Int      @map("room_id")
  userId    Int      @map("user_id")
  body      String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  room                    ChatRoom                   @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                    User                       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reactions               ChatMessageReaction[]
  guestReactions          ChatMessageGuestReaction[]
  sharedFromDirectMessage DirectMessage?             @relation("DirectMessageLobbyShare")

  @@index([roomId, createdAt], map: "ix_chat_messages_room_created_at")
  @@index([userId, createdAt], map: "ix_chat_messages_user_created_at")
  @@map("chat_messages")
}

model ChatMessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  userId    Int      @map("user_id")
  emoji     String   @db.VarChar(24)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([messageId, userId, emoji], map: "uq_chat_message_reactions_message_user_emoji")
  @@index([messageId, createdAt], map: "ix_chat_message_reactions_message_id")
  @@index([userId, createdAt], map: "ix_chat_message_reactions_user_id")
  @@map("chat_message_reactions")
}

model ChatMessageGuestReaction {
  id             Int      @id @default(autoincrement())
  messageId      Int      @map("message_id")
  guestSessionId String   @map("guest_session_id") @db.VarChar(64)
  emoji          String   @db.VarChar(24)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([messageId, guestSessionId, emoji], map: "uq_chat_message_guest_reactions_message_session_emoji")
  @@index([messageId, createdAt], map: "ix_chat_message_guest_reactions_message_id")
  @@index([guestSessionId, createdAt], map: "ix_chat_message_guest_reactions_guest_session_id")
  @@map("chat_message_guest_reactions")
}

model DirectConversation {
  id        Int      @id @default(autoincrement())
  pairKey   String   @unique(map: "uq_direct_conversations_pair_key") @map("pair_key") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  participants DirectConversationParticipant[]
  messages     DirectMessage[]

  @@map("direct_conversations")
}

model DirectConversationParticipant {
  id              Int       @id @default(autoincrement())
  conversationId  Int       @map("conversation_id")
  userId          Int       @map("user_id")
  joinedAt        DateTime  @default(now()) @map("joined_at") @db.Timestamp(6)
  lastReadAt      DateTime? @map("last_read_at") @db.Timestamp(6)
  typingUpdatedAt DateTime? @map("typing_updated_at") @db.Timestamp(6)

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user         User               @relation("DirectConversationParticipantUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([conversationId, userId], map: "uq_direct_conversation_participants_conversation_user")
  @@index([userId, lastReadAt], map: "ix_direct_conversation_participants_user_last_read_at")
  @@index([conversationId], map: "ix_direct_conversation_participants_conversation_id")
  @@map("direct_conversation_participants")
}

model DirectMessage {
  id                        Int      @id @default(autoincrement())
  conversationId            Int      @map("conversation_id")
  senderUserId              Int      @map("sender_user_id")
  body                      String?  @db.Text
  attachmentKind            String?  @map("attachment_kind") @db.VarChar(20)
  attachmentName            String?  @map("attachment_name") @db.VarChar(255)
  attachmentMimeType        String?  @map("attachment_mime_type") @db.VarChar(120)
  attachmentDataUrl         String?  @map("attachment_data_url") @db.Text
  attachmentDurationSeconds Int?     @map("attachment_duration_seconds")
  sharedLobbyMessageId      Int?     @unique(map: "uq_direct_messages_shared_lobby_message_id") @map("shared_lobby_message_id")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  conversation       DirectConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender             User                    @relation("DirectMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reactions          DirectMessageReaction[]
  sharedLobbyMessage ChatMessage?            @relation("DirectMessageLobbyShare", fields: [sharedLobbyMessageId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([conversationId, createdAt], map: "ix_direct_messages_conversation_created_at")
  @@index([senderUserId, createdAt], map: "ix_direct_messages_sender_created_at")
  @@map("direct_messages")
}

model DirectMessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  userId    Int      @map("user_id")
  emoji     String   @db.VarChar(24)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  message DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([messageId, userId, emoji], map: "uq_direct_message_reactions_message_user_emoji")
  @@index([messageId, createdAt], map: "ix_direct_message_reactions_message_id")
  @@index([userId, createdAt], map: "ix_direct_message_reactions_user_id")
  @@map("direct_message_reactions")
}

model CommunityRequest {
  id                Int       @id @default(autoincrement())
  title             String    @db.VarChar(160)
  body              String    @db.Text
  status            String    @default("open") @db.VarChar(20)
  createdByUserId   Int       @map("created_by_user_id")
  completedByUserId Int?      @map("completed_by_user_id")
  completedAt       DateTime? @map("completed_at") @db.Timestamp(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  author      User                      @relation("CommunityRequestAuthor", fields: [createdByUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  completedBy User?                     @relation("CommunityRequestCompleter", fields: [completedByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  votes       CommunityRequestVote[]
  comments    CommunityRequestComment[]

  @@index([status, createdAt], map: "ix_community_requests_status_created_at")
  @@index([completedAt], map: "ix_community_requests_completed_at")
  @@index([createdByUserId, createdAt], map: "ix_community_requests_created_by_user_id")
  @@map("community_requests")
}

model CommunityRequestVote {
  id        Int      @id @default(autoincrement())
  requestId Int      @map("request_id")
  userId    Int      @map("user_id")
  value     Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  request CommunityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([requestId, userId], map: "uq_community_request_votes_request_user")
  @@index([requestId, updatedAt], map: "ix_community_request_votes_request_id")
  @@index([userId, updatedAt], map: "ix_community_request_votes_user_id")
  @@map("community_request_votes")
}

model CommunityRequestComment {
  id           Int      @id @default(autoincrement())
  requestId    Int      @map("request_id")
  authorUserId Int      @map("author_user_id")
  parentId     Int?     @map("parent_id")
  body         String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  request CommunityRequest          @relation(fields: [requestId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  author  User                      @relation("CommunityRequestCommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent  CommunityRequestComment?  @relation("CommunityRequestCommentReplies", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  replies CommunityRequestComment[] @relation("CommunityRequestCommentReplies")

  @@index([requestId, parentId, createdAt], map: "ix_community_request_comments_request_parent_created_at")
  @@index([authorUserId, createdAt], map: "ix_community_request_comments_author_user_id")
  @@map("community_request_comments")
}

model UserBadge {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  label            String    @db.VarChar(40)
  note             String?   @db.VarChar(160)
  status           String    @default("pending") @db.VarChar(20)
  displayOnProfile Boolean   @default(false) @map("display_on_profile")
  acceptedAt       DateTime? @map("accepted_at") @db.Timestamp(6)
  createdByUserId  Int?      @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  user      User  @relation("UserBadgeRecipient", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdBy User? @relation("UserBadgeCreator", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([userId, label], map: "uq_user_badges_user_label")
  @@index([createdByUserId], map: "ix_user_badges_created_by_user_id")
  @@index([userId, createdAt], map: "ix_user_badges_user_created_at")
  @@index([userId, status, createdAt], map: "ix_user_badges_user_status_created_at")
  @@map("user_badges")
}

model UserGift {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  kind             String    @default("WOLO") @db.VarChar(40)
  amount           Int?
  note             String?   @db.VarChar(160)
  status           String    @default("pending") @db.VarChar(20)
  displayOnProfile Boolean   @default(false) @map("display_on_profile")
  acceptedAt       DateTime? @map("accepted_at") @db.Timestamp(6)
  createdByUserId  Int?      @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  user      User  @relation("UserGiftRecipient", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdBy User? @relation("UserGiftCreator", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([userId, createdAt], map: "ix_user_gifts_user_created_at")
  @@index([kind, createdAt], map: "ix_user_gifts_kind_created_at")
  @@index([createdByUserId], map: "ix_user_gifts_created_by_user_id")
  @@index([userId, status, createdAt], map: "ix_user_gifts_user_status_created_at")
  @@map("user_gifts")
}

model UserAppearancePreference {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique(map: "uq_user_appearance_preferences_user_id") @map("user_id")
  themeKey     String   @default("midnight") @map("theme_key") @db.VarChar(20)
  tileThemeKey String   @default("midnight") @map("tile_theme_key") @db.VarChar(20)
  viewMode     String   @default("steel") @map("view_mode") @db.VarChar(20)
  textColor    String   @default("white") @map("text_color") @db.VarChar(20)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  timeDisplayMode  String  @default("utc") @map("time_display_mode") @db.VarChar(20)
  timezoneOverride String? @map("timezone_override") @db.VarChar(80)

  @@map("user_appearance_preferences")
}

model UserActivityEvent {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(40)
  path      String?  @db.VarChar(160)
  label     String?  @db.VarChar(80)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt], map: "ix_user_activity_events_user_created_at")
  @@index([type, createdAt], map: "ix_user_activity_events_type_created_at")
  @@map("user_activity_events")
}

model WatcherDownloadEvent {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  userId    Int?     @map("user_id")
  platform  String   @db.VarChar(24)
  artifact  String   @db.VarChar(40)
  version   String   @db.VarChar(32)
  filename  String   @db.VarChar(180)
  ipAddress String?  @map("ip_address") @db.VarChar(80)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  referer   String?  @db.VarChar(255)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([createdAt], map: "ix_watcher_download_events_created_at")
  @@index([platform, artifact, createdAt], map: "ix_watcher_download_events_platform_artifact_created_at")
  @@index([userId, createdAt], map: "ix_watcher_download_events_user_id_created_at")
  @@map("watcher_download_events")
}

model BetMarket {
  id                    Int       @id @default(autoincrement())
  scheduledMatchId      Int?      @unique(map: "uq_bet_markets_scheduled_match_id") @map("scheduled_match_id")
  linkedSessionKey      String?   @map("linked_session_key") @db.VarChar(255)
  linkedGameStatsId     Int?      @map("linked_game_stats_id")
  slug                  String    @unique @db.VarChar(120)
  title                 String    @db.VarChar(160)
  eventLabel            String    @map("event_label") @db.VarChar(120)
  marketType            String    @default("winner") @map("market_type") @db.VarChar(32)
  status                String    @default("open") @db.VarChar(20)
  featured              Boolean   @default(false)
  sortOrder             Int       @default(0) @map("sort_order")
  leftLabel             String    @map("left_label") @db.VarChar(80)
  rightLabel            String    @map("right_label") @db.VarChar(80)
  leftHref              String?   @map("left_href") @db.VarChar(160)
  rightHref             String?   @map("right_href") @db.VarChar(160)
  seedLeftWolo          Int       @default(0) @map("seed_left_wolo")
  seedRightWolo         Int       @default(0) @map("seed_right_wolo")
  closeAt               DateTime? @map("close_at") @db.Timestamp(6)
  settledAt             DateTime? @map("settled_at") @db.Timestamp(6)
  winnerSide            String?   @map("winner_side") @db.VarChar(20)
  settlementRunId       String?   @map("settlement_run_id") @db.VarChar(128)
  settlementStatus      String?   @map("settlement_status") @db.VarChar(32)
  settlementFailureCode String?   @map("settlement_failure_code") @db.VarChar(80)
  settlementDetail      String?   @map("settlement_detail") @db.VarChar(255)
  settlementAttemptedAt DateTime? @map("settlement_attempted_at") @db.Timestamp(6)
  settlementExecutedAt  DateTime? @map("settlement_executed_at") @db.Timestamp(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  scheduledMatch ScheduledMatch? @relation(fields: [scheduledMatchId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  linkedGameStats GameStats?     @relation("BetMarketLinkedGameStats", fields: [linkedGameStatsId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  wagers         BetWager[]
  stakeIntents   BetStakeIntent[]
  walletLocks    BetMarketWallet[]
  founderBonuses BetMarketFounderBonus[]

  @@index([status, featured, sortOrder], map: "ix_bet_markets_status_featured_sort_order")
  @@index([closeAt], map: "ix_bet_markets_close_at")
  @@index([linkedSessionKey], map: "ix_bet_markets_linked_session_key")
  @@index([linkedGameStatsId], map: "ix_bet_markets_linked_game_stats_id")
  @@map("bet_markets")
}

model BetWager {
  id                 Int           @id @default(autoincrement())
  marketId           Int           @map("market_id")
  userId             Int           @map("user_id")
  stakeIntentId      Int?          @unique(map: "uq_bet_wagers_stake_intent_id") @map("stake_intent_id")
  side               String        @db.VarChar(20)
  amountWolo         Int           @map("amount_wolo")
  payoutWolo         Int?          @map("payout_wolo")
  status             String        @default("active") @db.VarChar(20)
  executionMode      String        @default("app_only") @map("execution_mode") @db.VarChar(20)
  stakeTxHash        String?       @unique(map: "uq_bet_wagers_stake_tx_hash") @map("stake_tx_hash") @db.VarChar(128)
  stakeWalletAddress String?       @map("stake_wallet_address") @db.VarChar(100)
  stakeLockedAt      DateTime?     @map("stake_locked_at") @db.Timestamp(6)
  payoutTxHash       String?       @map("payout_tx_hash") @db.VarChar(128)
  payoutProofUrl     String?       @map("payout_proof_url") @db.VarChar(500)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)
  settledAt          DateTime?     @map("settled_at") @db.Timestamp(6)

  market      BetMarket       @relation(fields: [marketId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stakeIntent BetStakeIntent? @relation(fields: [stakeIntentId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([userId, status, updatedAt], map: "ix_bet_wagers_user_status_updated_at")
  @@index([marketId, status, updatedAt], map: "ix_bet_wagers_market_status_updated_at")
  @@index([marketId, userId, side, status], map: "ix_bet_wagers_market_user_side_status")
  @@map("bet_wagers")
}

model BetMarketWallet {
  id            Int      @id @default(autoincrement())
  marketId      Int      @map("market_id")
  userId        Int?     @map("user_id")
  walletAddress String   @map("wallet_address") @db.VarChar(100)
  side          String   @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  market BetMarket @relation(fields: [marketId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user   User?     @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([marketId, walletAddress], map: "uq_bet_market_wallets_market_wallet")
  @@index([marketId, side], map: "ix_bet_market_wallets_market_side")
  @@index([userId], map: "ix_bet_market_wallets_user_id")
  @@map("bet_market_wallets")
}

model PendingWoloClaim {
  id                   Int       @id @default(autoincrement())
  normalizedPlayerName String    @map("normalized_player_name") @db.VarChar(64)
  displayPlayerName    String    @map("display_player_name") @db.VarChar(100)
  amountWolo           Int       @map("amount_wolo")
  claimKind            String    @default("bet_payout") @map("claim_kind") @db.VarChar(40)
  claimGroupKey        String    @default("market") @map("claim_group_key") @db.VarChar(80)
  targetScope          String?   @map("target_scope") @db.VarChar(32)
  status               String    @default("pending") @db.VarChar(20)
  sourceMarketId       Int?      @map("source_market_id")
  sourceGameStatsId    Int?      @map("source_game_stats_id")
  sourceFounderBonusId Int?      @map("source_founder_bonus_id")
  claimedByUserId      Int?      @map("claimed_by_user_id")
  rescindedByUserId    Int?      @map("rescinded_by_user_id")
  payoutTxHash         String?   @map("payout_tx_hash") @db.VarChar(128)
  payoutProofUrl       String?   @map("payout_proof_url") @db.VarChar(500)
  errorState           String?   @map("error_state") @db.VarChar(255)
  payoutAttemptedAt    DateTime? @map("payout_attempted_at") @db.Timestamp(6)
  note                 String?   @db.VarChar(160)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  claimedAt            DateTime? @map("claimed_at") @db.Timestamp(6)
  rescindedAt          DateTime? @map("rescinded_at") @db.Timestamp(6)

  sourceFounderBonus BetMarketFounderBonus? @relation(fields: [sourceFounderBonusId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([sourceMarketId, normalizedPlayerName, claimKind, claimGroupKey], map: "uq_pending_wolo_claims_market_player_kind_group")
  @@index([normalizedPlayerName, status], map: "ix_pending_wolo_claims_name_status")
  @@index([claimedByUserId, status], map: "ix_pending_wolo_claims_claimed_by_status")
  @@index([sourceMarketId], map: "ix_pending_wolo_claims_source_market_id")
  @@index([sourceGameStatsId], map: "ix_pending_wolo_claims_source_game_stats_id")
  @@index([sourceFounderBonusId], map: "ix_pending_wolo_claims_source_founder_bonus_id")
  @@map("pending_wolo_claims")
}

model BetMarketFounderBonus {
  id              Int       @id @default(autoincrement())
  marketId        Int       @map("market_id")
  bonusType       String    @map("bonus_type") @db.VarChar(24)
  totalAmountWolo Int       @map("total_amount_wolo")
  note            String?   @db.VarChar(160)
  status          String    @default("armed") @db.VarChar(24)
  createdByUserId Int?      @map("created_by_user_id")
  failureReason   String?   @map("failure_reason") @db.VarChar(255)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  settledAt       DateTime? @map("settled_at") @db.Timestamp(6)
  rescindedAt     DateTime? @map("rescinded_at") @db.Timestamp(6)

  market     BetMarket          @relation(fields: [marketId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  createdBy  User?              @relation("BetMarketFounderBonusCreator", fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  claims     PendingWoloClaim[]

  @@index([marketId, createdAt], map: "ix_bet_market_founder_bonuses_market_created_at")
  @@index([status, createdAt], map: "ix_bet_market_founder_bonuses_status_created_at")
  @@map("bet_market_founder_bonuses")
}

model BetStakeIntent {
  id             Int       @id @default(autoincrement())
  marketId       Int       @map("market_id")
  userId         Int       @map("user_id")
  side           String    @db.VarChar(20)
  amountWolo     Int       @map("amount_wolo")
  walletAddress  String?   @map("wallet_address") @db.VarChar(100)
  walletProvider String?   @map("wallet_provider") @db.VarChar(32)
  walletType     String?   @map("wallet_type") @db.VarChar(32)
  browserInfo    String?   @map("browser_info") @db.VarChar(255)
  routePath      String?   @map("route_path") @db.VarChar(160)
  status         String    @default("awaiting_signature") @db.VarChar(32)
  stakeTxHash    String?   @unique(map: "uq_bet_stake_intents_stake_tx_hash") @map("stake_tx_hash") @db.VarChar(128)
  errorDetail    String?   @map("error_detail") @db.VarChar(255)
  verifiedAt     DateTime? @map("verified_at") @db.Timestamp(6)
  recordedAt     DateTime? @map("recorded_at") @db.Timestamp(6)
  orphanedAt     DateTime? @map("orphaned_at") @db.Timestamp(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  market BetMarket  @relation(fields: [marketId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wager  BetWager?

  @@index([userId, status, updatedAt], map: "ix_bet_stake_intents_user_status_updated_at")
  @@index([marketId, status, updatedAt], map: "ix_bet_stake_intents_market_status_updated_at")
  @@map("bet_stake_intents")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}
