  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  events            StakingEvent[]
  rewardAllocations StakingRewardAllocation[]

  @@index([status, currentStakedWolo], map: "ix_staking_positions_status_current_staked")
  @@index([walletAddress], map: "ix_staking_positions_wallet_address")
  @@map("staking_positions")
}

model StakingEvent {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  positionId    Int?      @map("position_id")
  walletAddress String?   @map("wallet_address") @db.VarChar(100)
  type          String    @db.VarChar(24)
  amountWolo    Int       @default(0) @map("amount_wolo")
  txHash        String?   @map("tx_hash") @db.VarChar(128)
  status        String    @default("PENDING_CHAIN") @db.VarChar(32)
  weightBefore  BigInt    @default(0) @map("weight_before")
  weightAfter   BigInt    @default(0) @map("weight_after")
  balanceBefore Int       @default(0) @map("balance_before_wolo")
  balanceAfter  Int       @default(0) @map("balance_after_wolo")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  confirmedAt   DateTime? @map("confirmed_at") @db.Timestamp(6)

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  position StakingPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([userId, status, createdAt], map: "ix_staking_events_user_status_created")
  @@index([status, createdAt], map: "ix_staking_events_status_created")
  @@index([txHash], map: "ix_staking_events_tx_hash")
  @@map("staking_events")
}

model WoloIndexedTransfer {
  id                Int      @id @default(autoincrement())
  chainId           String   @map("chain_id") @db.VarChar(32)
  txHash            String   @map("tx_hash") @db.VarChar(128)
  transferIndex     Int      @default(0) @map("transfer_index")
  height            BigInt
  timestamp         DateTime @db.Timestamp(6)
  senderAddress     String   @map("sender_address") @db.VarChar(100)
  recipientAddress  String   @map("recipient_address") @db.VarChar(100)
  amountUwolo       BigInt   @map("amount_uwolo")
  amountWoloDisplay Decimal  @map("amount_wolo_display") @db.Decimal(20, 6)
  denom             String   @db.VarChar(32)
  memo              String?
  rawType           String?  @map("raw_type") @db.VarChar(100)
  eventType         String?  @map("event_type") @db.VarChar(80)
  source            String   @default("wolo-mainnet-bank-send") @db.VarChar(80)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@unique([txHash, transferIndex], map: "uq_wolo_indexed_transfers_tx_hash_transfer_index")
  @@index([chainId, height], map: "ix_wolo_indexed_transfers_chain_height")
  @@index([txHash], map: "ix_wolo_indexed_transfers_tx_hash")
  @@index([senderAddress], map: "ix_wolo_indexed_transfers_sender")
  @@index([recipientAddress], map: "ix_wolo_indexed_transfers_recipient")
  @@index([timestamp], map: "ix_wolo_indexed_transfers_timestamp")
  @@map("wolo_indexed_transfers")
}

model StakingRewardDistribution {
  id                        Int       @id @default(autoincrement())
  distributionDate          DateTime  @map("distribution_date") @db.Date
  periodStart               DateTime  @map("period_start") @db.Timestamp(6)
  periodEnd                 DateTime  @map("period_end") @db.Timestamp(6)
  bettingFeePoolWolo        Int       @default(0) @map("betting_fee_pool_wolo")
  stakerPoolWolo            Int       @default(0) @map("staker_pool_wolo")
  treasuryPoolWolo          Int       @default(0) @map("treasury_pool_wolo")
  totalWeight               BigInt    @default(0) @map("total_weight")
  status                    String    @default("DRAFT") @db.VarChar(24)
  treasuryPayoutStatus      String    @default("UNPAID") @map("treasury_payout_status") @db.VarChar(24)
  treasuryPayoutRequestId   String    @map("treasury_payout_request_id") @db.VarChar(128)
  treasuryPayoutTxHash      String?   @map("treasury_payout_tx_hash") @db.VarChar(100)
  treasuryPayoutAttemptedAt DateTime? @map("treasury_payout_attempted_at") @db.Timestamp(6)
  treasuryPayoutExecutedAt  DateTime? @map("treasury_payout_executed_at") @db.Timestamp(6)
  treasuryPayoutError       String?   @map("treasury_payout_error")
  metadata                  Json?
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  finalizedAt               DateTime? @map("finalized_at") @db.Timestamp(6)

  allocations StakingRewardAllocation[]

  @@unique([distributionDate], map: "uq_staking_reward_distributions_date")
  @@unique([treasuryPayoutRequestId], map: "uq_staking_reward_distributions_treasury_request")
  @@index([status, distributionDate], map: "ix_staking_reward_distributions_status_date")
  @@index([treasuryPayoutStatus, distributionDate], map: "ix_staking_reward_distributions_treasury_status_date")
  @@index([treasuryPayoutTxHash], map: "ix_staking_reward_distributions_treasury_tx_hash")
  @@map("staking_reward_distributions")
}

model StakingRewardAllocation {
  id             Int       @id @default(autoincrement())
  distributionId Int       @map("distribution_id")
  userId         Int       @map("user_id")
  positionId     Int?      @map("position_id")
  walletAddress  String?   @map("wallet_address") @db.VarChar(100)
  userWeight     BigInt    @default(0) @map("user_weight")
  totalWeight    BigInt    @default(0) @map("total_weight")
  rewardWolo     Int       @default(0) @map("reward_wolo")
  status         String    @default("PENDING") @db.VarChar(24)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  creditedAt     DateTime? @map("credited_at") @db.Timestamp(6)
  claimedAt      DateTime? @map("claimed_at") @db.Timestamp(6)

  distribution StakingRewardDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  position     StakingPosition?          @relation(fields: [positionId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([distributionId, userId], map: "uq_staking_reward_allocations_distribution_user")
  @@index([userId, status, createdAt], map: "ix_staking_reward_allocations_user_status_created")
  @@map("staking_reward_allocations")
}

model StakingDailyStat {
  id                  Int      @id @default(autoincrement())
  date                DateTime @db.Date
  totalStakedWolo     Int      @default(0) @map("total_staked_wolo")
  activeStakers       Int      @default(0) @map("active_stakers")
  totalWeight         BigInt   @default(0) @map("total_weight")
  stakerRewardsWolo   Int      @default(0) @map("staker_rewards_wolo")
  treasuryRevenueWolo Int      @default(0) @map("treasury_revenue_wolo")
  betVolumeWolo       Int      @default(0) @map("bet_volume_wolo")
  betsPlaced          Int      @default(0) @map("bets_placed")
  activeBettors       Int      @default(0) @map("active_bettors")
  activePlayers       Int      @default(0) @map("active_players")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@unique([date], map: "uq_staking_daily_stats_date")
  @@map("staking_daily_stats")
}

model GameWatchStream {
  id              Int       @id @default(autoincrement())
  sessionKey      String    @map("session_key") @db.VarChar(255)
  userId          Int?      @map("user_id")
  provider        String    @db.VarChar(24)
  sourceType      String    @default("external") @map("source_type") @db.VarChar(32)
  role            String    @db.VarChar(24)
  label           String    @db.VarChar(80)
  title           String?   @db.VarChar(140)
  url             String    @db.VarChar(500)
  playbackUrl     String?   @map("playback_url") @db.VarChar(500)
  embedId         String?   @map("embed_id") @db.VarChar(255)
  playerLabel     String?   @map("player_label") @db.VarChar(80)
  thumbnailUrl    String?   @map("thumbnail_url") @db.Text
  mediaMimeType   String?   @map("media_mime_type") @db.VarChar(120)
  isPrimary       Boolean   @default(false) @map("is_primary")
  status          String    @default("live") @db.VarChar(24)
  chunkCount      Int       @default(0) @map("chunk_count")
  latestChunkSeq  Int       @default(-1) @map("latest_chunk_seq")
  lastHeartbeatAt DateTime? @map("last_heartbeat_at") @db.Timestamp(6)
  startedAt       DateTime? @map("started_at") @db.Timestamp(6)
  endedAt         DateTime? @map("ended_at") @db.Timestamp(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  user User? @relation("GameWatchStreamOwner", fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([sessionKey, isPrimary], map: "ix_game_watch_streams_session_primary")
  @@index([sessionKey, status], map: "ix_game_watch_streams_session_status")
  @@index([userId, status], map: "ix_game_watch_streams_user_status")
  @@index([sourceType, status], map: "ix_game_watch_streams_source_status")
  @@index([provider], map: "ix_game_watch_streams_provider")
  @@map("game_watch_streams")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}
