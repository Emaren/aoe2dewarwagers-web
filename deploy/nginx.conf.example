# Example production nginx routing for AoE2DEWarWagers
# Adjust TLS cert paths and domain names to your environment.

server {
    listen 80;
    server_name aoe2dewarwagers.com www.aoe2dewarwagers.com;
    return 301 https://aoe2dewarwagers.com$request_uri;
}

server {
    listen 443 ssl http2;
    server_name aoe2dewarwagers.com;

    # ssl_certificate     /etc/letsencrypt/live/aoe2dewarwagers.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/aoe2dewarwagers.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

server {
    listen 80;
    server_name api-prodn.aoe2dewarwagers.com;
    return 301 https://api-prodn.aoe2dewarwagers.com$request_uri;
}

server {
    listen 443 ssl http2;
    server_name api-prodn.aoe2dewarwagers.com;

    # ssl_certificate     /etc/letsencrypt/live/api-prodn.aoe2dewarwagers.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api-prodn.aoe2dewarwagers.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:4400;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
